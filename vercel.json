{
    "version": 2,
    "framework": null,
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|fonts|favicon.ico|robots.txt|build)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/index.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_LOCALE": "ar",
        "APP_DEBUG": "true",
        "VERCEL": "1",
        "APP_URL": "https://scientific-conference.vercel.app",
        "ASSET_URL": "https://scientific-conference.vercel.app",
        "SANCTUM_STATEFUL_DOMAINS": "scientific-conference.vercel.app",
        "DB_CONNECTION": "pgsql",
        "DB_HOST": "aws-1-ap-southeast-1.pooler.supabase.com",
        "DB_PORT": "6543",
        "DB_DATABASE": "postgres",
        "DB_USERNAME": "postgres.ygjjurnheomesuyvgoie",
        "DB_PASSWORD": "huskF53DCciS3xLm",
        "DB_SSLMODE": "require",
        "APP_KEY": "base64:N74gLVjwsCL5lxFBjWWlspmA591jBRAVEBzPgY6yaWQ=",
        "LOG_CHANNEL": "stderr",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "SESSION_DRIVER": "cookie"
    }
}
